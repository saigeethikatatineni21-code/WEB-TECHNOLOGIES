<!DOCTYPE html>
<html>
<head>
    <title>Job Registration Form</title>
</head>
<body>
    <h2>Job Registration Form</h2>
    <form>
      
        <label for="name">Full Name:</label>
        <input type="text" id="name" name="name" required><br><br>

        <label>Gender:</label>
        <input type="radio" id="male" name="gender" value="Male">
        <label for="male">Male</label>
        <input type="radio" id="female" name="gender" value="Female">
        <label for="female">Female</label>
        <input type="radio" id="other" name="gender" value="Other">
        <label for="other">Other</label><br><br>

        <label>Languages Known:</label><br>
        <input type="checkbox" id="english" name="languages" value="English">
        <label for="english">English</label><br>
        <input type="checkbox" id="hindi" name="languages" value="Hindi">
        <label for="hindi">Hindi</label><br>
        <input type="checkbox" id="telugu" name="languages" value="Telugu">
        <label for="telugu">Telugu</label><br><br>

        <label for="email">Email:</label>
        <input type="email" id="email" name="email" required><br><br>

        <label for="contact">Contact Number:</label>
        <input type="tel" id="contact" name="contact" required><br><br>

        <label for="address">Address:</label><br>
        <textarea id="address" name="address" rows="4" cols="40"></textarea><br><br>

        <label for="location">Preferred Job Location:</label>
        <select id="location" name="location">
            <option value="Hyderabad">Hyderabad</option>
            <option value="Bangalore">Bangalore</option>
            <option value="Chennai">Chennai</option>
            <option value="Delhi">Delhi</option>
        </select><br><br>

        <label for="about">Describe Yourself:</label><br>
        <textarea id="about" name="about" rows="5" cols="50"></textarea><br><br>

        <label for="cv">Upload CV:</label>
        <input type="file" id="cv" name="cv"><br><br>

        <input type="reset" value="Clear Form">
        <input type="submit" value="Submit Form">
    </form>
</body>
</html>
